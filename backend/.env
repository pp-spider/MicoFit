# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=xxxxxx
DB_NAME=micofit_db

# JWT 配置
SECRET_KEY=xxxxxx
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS 配置
FRONTEND_URL=http://localhost:3000

# 应用配置
APP_NAME=微动 MicoFit API
APP_VERSION=1.0.0
DEBUG=True

# AI 配置（使用 Moonshot/Kimi API，与 OpenAI 兼容）
OPENAI_API_KEY=xxxxxx
OPENAI_MODEL=deepseek-chat
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=8192